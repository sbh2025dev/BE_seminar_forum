<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Post List</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        max-width: 900px;
        margin: 0 auto;
        padding: 20px;
      }
      nav {
        margin-bottom: 20px;
      }
      nav a {
        margin-right: 15px;
        text-decoration: none;
        color: #333;
      }
      nav a:hover {
        text-decoration: underline;
      }
      .post {
        border: 1px solid #ddd;
        border-radius: 4px;
        padding: 15px;
        margin-bottom: 10px;
      }
      .post h2 {
        margin: 0 0 8px 0;
        font-size: 1.1rem;
      }
      .post p {
        margin: 0;
        color: #555;
      }
      .post:hover {
        background-color: #f5f5f5;
        border-color: #bbb;
      }
      .post-wrapper {
        display: flex;
        align-items: stretch;
        margin-bottom: 10px;
      }
      .post-wrapper > a:first-child {
        flex: 1;
      }
      .post-wrapper > a:first-child .post {
        margin-bottom: 0;
      }
      .edit-btn {
        margin-left: 10px;
        padding: 15px 20px;
        font-size: 1rem;
        font-family: Arial, sans-serif;
        cursor: pointer;
        border: 1px solid #ddd;
        border-radius: 4px;
        background-color: #fff;
        color: #333;
        white-space: nowrap;
      }
      .edit-btn:hover {
        background-color: #f5f5f5;
        border-color: #bbb;
      }
    </style>
  </head>
  <body>
    <%- include('nav') %>
    
    <h1>Posts (<%= posts.length %>)</h1>

    <% for (let i = 0; i < posts.length; i++) { %>

    <div class="post-wrapper">
      <a href="/detail/<%= posts[i]._id %>" style="text-decoration:none; color:inherit;">
        <div class="post">
          <h2><%= posts[i].title %></h2>
          <p><%= posts[i].content %></p>
        </div>
      </a>
      <a href="/edit/<%= posts[i]._id %>">
        <button class="edit-btn">Edit</button>
      </a>
    </div>

    <% } %>
  </body>
</html>
